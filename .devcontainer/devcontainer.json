{
  "name": "Python",
  "image": "mcr.microsoft.com/devcontainers/python:latest",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/STATIC/.venv/bin/python",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "python.formatting.provider": "black"
      }
    }
  },
  "forwardPorts": [],
  "remoteUser": "vscode",
  "postCreateCommand": "python3 -m venv /workspaces/STATIC/.venv && /workspaces/STATIC/.venv/bin/python -m pip install --upgrade pip setuptools wheel && /workspaces/STATIC/.venv/bin/pip install -e /workspaces/STATIC/static"
}
